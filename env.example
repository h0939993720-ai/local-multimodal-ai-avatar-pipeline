# =========================
# OpenAI API（app.py 必填）
# =========================
OPENAI_API_KEY=your_openai_api_key_here

# =========================
# FFmpeg / FFprobe 路徑
# 若系統 PATH 已包含 ffmpeg，可留空（將使用預設值 "ffmpeg" / "ffprobe"）
# Windows 範例：
#   FFMPEG_PATH=C:\ffmpeg\ffmpeg-8.1-essentials_build\bin\ffmpeg.exe
#   FFPROBE_PATH=C:\ffmpeg\ffmpeg-8.1-essentials_build\bin\ffprobe.exe
# =========================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# =========================
# MuseTalk 結果輸出資料夾
# liveportrait_server.py 會從這裡複製 MuseTalk 產生的影片
# 預設為 ../MuseTalk/results/output（相對於 project 資料夾）
# Windows 範例：
#   MUSETALK_RESULTS_DIR=C:\Users\USER\Desktop\MuseTalk\results\output
# =========================
MUSETALK_RESULTS_DIR=

# =========================
# HTTPS 憑證（可選，app.py 預設不啟用 SSL）
# =========================
SSL_CERT=www.ccchen.site-crt.pem
SSL_KEY=www.ccchen.site-key.pem
